<?xml version="1.0" encoding="UTF-8"?>
<gexf xmlns="http://www.gexf.net/1.3" version="1.3">
  <graph defaultedgetype="directed">
    <attributes class="node">
      <attribute id="0" title="name" type="string"/>
    </attributes>
    <nodes>
      <node id="0" label="User">
        <attvalues>
          <attvalue for="0" value="Alice"/>
        </attvalues>
      </node>
      <node id="1" label="User">
        <attvalues>
          <attvalue for="0" value="Bob"/>
        </attvalues>
      </node>
      <node id="2" label="User">
        <attvalues>
          <attvalue for="0" value="Charlie"/>
        </attvalues>
      </node>
      <node id="3" label="User">
        <attvalues>
          <attvalue for="0" value="Diana"/>
        </attvalues>
      </node>
    </nodes>
    <edges>
      <!-- Directed edges -->
      <edge id="e0" source="0" target="1" label="FOLLOWS"/>
      <edge id="e1" source="1" target="2" label="FOLLOWS"/>
      <!-- Undirected edges (bidirectional relationship) -->
      <edge id="e2" source="0" target="3" type="undirected" label="FRIEND"/>
      <edge id="e3" source="2" target="3" type="undirected" label="FRIEND"/>
    </edges>
  </graph>
</gexf>
